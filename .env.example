# Database
DATABASE_URL="postgresql://user:password@localhost:5432/flupflap"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Platform fee (percentage, default 3)
PLATFORM_FEE_PERCENT="3"

# Cloudinary — required for seller image uploads
# Create a free account at https://cloudinary.com and copy the values from
# your dashboard (Settings → API Keys).
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Twilio — required for seller two-factor authentication (phone OTP)
# Create an account at https://www.twilio.com and obtain these values from
# the Twilio Console (twilio.com/console).
# Leave unset (or blank) to run in dev/mock mode: the OTP is logged to the
# server console instead of being sent by SMS.  Do NOT leave unset in production.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_NUMBER="+15005550006"

# SMS OTP feature flag — set to "true" to require sellers to verify a Twilio
# SMS code on every login (full two-factor authentication).
# Set to "false" or leave unset to allow sellers to log in with email + password
# only.  Use "false" while Twilio A2P registration is pending approval.
# Once Twilio approval is complete, set this to "true" and redeploy.
ENABLE_SMS_OTP="false"
