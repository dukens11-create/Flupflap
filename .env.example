# Database
DATABASE_URL="postgresql://user:password@localhost:5432/flupflap"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
# Required for payments and seller payouts (Stripe Connect).
# Use test keys (sk_test_... / pk_test_...) for development.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook signing secret — obtain from the Stripe Dashboard under
# Developers → Webhooks.  The webhook endpoint must receive:
#   - checkout.session.completed   (order creation)
#   - account.updated              (seller Connect onboarding status sync)
#   - identity.verification_session.* (seller KYC identity status sync)
# For local development use the Stripe CLI:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Firebase (seller signup phone verification)
# Enable Phone Authentication in Firebase Auth and use a web app config.
# `FIREBASE_API_KEY` is used server-side to validate the verified phone ID token.
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
FIREBASE_API_KEY="AIza..."

# Shippo shipping labels (seller fulfillment)
# Required for live shipping-rate comparison and label purchase.
SHIPPO_API_TOKEN="shippo_live_..."

# Mapbox public token for checkout address autocomplete.
# Use only a public token here (NEXT_PUBLIC_ vars are exposed to the browser).
NEXT_PUBLIC_MAPBOX_TOKEN="your_mapbox_public_token"

# Legacy platform fee bootstrap env var (the app normalizes paid seller items to 7%)
PLATFORM_FEE_PERCENT="7"

# Cloudinary — optional; used for seller product media uploads, AI image enhancement,
# and seller verification docs.
# When these variables are set, profile photos, product images, and product videos
# are stored in Cloudinary.
# When omitted, profile photos fall back to base64 data-URL storage in the database
# (suitable for development / small deployments; Cloudinary is recommended for production).
# Create a free account at https://cloudinary.com and copy the values from
# your dashboard (Settings → API Keys).
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_PRODUCT_MEDIA_FOLDER="flupflap/products"
CLOUDINARY_PRODUCT_VIDEO_FOLDER="flupflap/videos"
CLOUDINARY_VERIFICATION_FOLDER="flupflap/seller-verification"

# Seller KYC provider (stripe | persona | manual)
KYC_PROVIDER="stripe"

# Persona KYC (required only when KYC_PROVIDER=persona)
PERSONA_API_KEY="persona_live_..."
PERSONA_TEMPLATE_ID="itmpl_..."
PERSONA_WEBHOOK_SECRET="persona_webhook_secret"

# Twilio — required for seller two-factor authentication (phone OTP)
# Create an account at https://www.twilio.com and obtain these values from
# the Twilio Console (twilio.com/console).
# Leave unset (or blank) to run in dev/mock mode: the OTP is logged to the
# server console instead of being sent by SMS.  Do NOT leave unset in production.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_FROM_NUMBER="+15005550006"

# SMS OTP feature flag — enabled by default for seller logins now that Twilio
# is approved. Leave unset or set to "true" to require the Twilio SMS code on
# every seller login (full two-factor authentication).
# Set to "false" only as a temporary emergency fallback if SMS delivery must be
# bypassed while the provider is unavailable.
ENABLE_SMS_OTP="true"

# Resend — required for transactional emails (password-reset links, etc.)
# Create a free account at https://resend.com, verify your sending domain, and
# paste the API key below.  Leave unset (or blank) to run in dev/mock mode: the
# email body is logged to the server console instead of being delivered.
# Do NOT leave unset in production.
RESEND_API_KEY="re_..."
# The "From" address used in outgoing emails.  Must belong to a domain you have
# verified in the Resend dashboard.  Defaults to "noreply@flupflap.com".
RESEND_FROM_EMAIL="noreply@flupflap.com"

# Sentry — optional; used for production error monitoring and performance tracking.
# Create a free project at https://sentry.io and copy the DSN from your project
# settings (Settings → Client Keys → DSN).
# Leave unset (or blank) in development — the app continues to work and errors
# are only logged to the console.
#
# Server-side DSN (API routes, Server Components, edge middleware):
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# Browser/client-side DSN (visible to browsers — safe to expose):
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
# Optional: override the reported environment name (defaults to NODE_ENV).
SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
# Required for source-map upload during CI/CD builds (Settings → Auth Tokens).
# Leave unset locally — source-map upload is skipped gracefully when absent.
# SENTRY_AUTH_TOKEN="sntrys_..."
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="flupflap"

# KYC stats debug logging — set to "true" to emit a per-seller log line showing
# email address and detected KYC status on every admin page load.  Disabled by
# default to avoid logging PII (email addresses) in production.
# NOTE: This flag is silently ignored when NODE_ENV=production.
# DEBUG_KYC_STATS="true"
