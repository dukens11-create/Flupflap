generator client {
  provider = "prisma-client-js"
}

// Database connection URL is configured in prisma.config.ts (Prisma 7 pattern)
datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

enum SellerStatus {
  ACTIVE
  PENDING
  RESTRICTED
  SUSPENDED
  BANNED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum SellerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SellerPhoneVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
}

enum SellerKycProvider {
  STRIPE
  PERSONA
  MANUAL
}

enum SellerAdminFallbackStatus {
  NOT_REQUIRED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PENDING
  APPROVED
  REJECTED
  SOLD
  ARCHIVED
  HIDDEN
}

enum ProductSizeType {
  BABY
  CLOTHING
  SHOES
  PANTS
  DRESS
  CUSTOM
}

enum ReportStatus {
  OPEN
  DISMISSED
  RESOLVED
}

enum PromotionStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum SalesPromotionKind {
  DISCOUNT
  OFFER
}

enum SalesPromotionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  EXPIRED
  ARCHIVED
}

enum SellerDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum SellerPromotionTriggerType {
  ANY_PURCHASE
  MIN_SPEND
  MIN_QUANTITY
}

enum SellerPromotionRewardType {
  FREE_ITEM
}

enum NotificationType {
  ORDER_UPDATE
  OFFER
  MESSAGE
  PAYOUT
  SHIPPING
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  REFUND_REQUESTED
  PARTIALLY_REFUNDED
  CANCELLED
  REFUNDED
  READY_FOR_PICKUP
  PICKED_UP
}

enum RefundRequestStatus {
  REQUESTED
  SELLER_REVIEW
  APPROVED
  DENIED
  REFUNDED
}

// ── Garage Sales ──────────────────────────────────────────────────────────────

enum GarageSaleType {
  GARAGE_SALE
  YARD_SALE
  ESTATE_SALE
  MOVING_SALE
}

enum GarageSaleStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  HIDDEN
}

enum GarageSalePromotionType {
  FEATURED
  HOMEPAGE_BOOST
  LOCAL_AREA_BOOST
  WEEKEND_PROMOTION
}

enum GarageSaleListingType {
  STANDARD
  FEATURED
}

enum GarageSalePaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  password                 String
  role                     Role                      @default(CUSTOMER)
  roles                    Role[]                    @default([CUSTOMER])
  phone                    String?
  stripeAccountId          String?
  stripeAccountMode        String?
  stripeOnboardingComplete Boolean                   @default(false)
  deletedAt                DateTime?
  deletionReason           String?
  deletionReasonOther      String?
  sellerStatus             SellerStatus              @default(ACTIVE)
  sellerStatusReason       String?
  sellerStatusNotes        String?
  kycStatus                KycStatus                 @default(NOT_SUBMITTED)
  verifiedSeller           Boolean                   @default(false)
  approvedAt               DateTime?
  phoneVerified            Boolean                   @default(false)
  phoneVerifiedAt          DateTime?
  createdAt                DateTime                  @default(now())
  products                 Product[]
  orders                   Order[]
  addresses                Address[]
  accounts                 Account[]
  sessions                 Session[]
  sellerOtp                SellerOtp?
  phoneVerificationToken   PhoneVerificationToken?
  verificationSubmission   SellerVerification?        @relation("SellerVerificationSubmission")
  reviewedVerifications    SellerVerification[]       @relation("SellerVerificationReviewer")
  moderationLogsAsSeller   SellerModerationLog[]     @relation("ModeratedSeller")
  moderationLogsAsAdmin    SellerModerationLog[]     @relation("AdminModerator")
  adminAccessLogs          AdminAccessLog[]          @relation("AdminAccessor")
  accessedByAdminLogs      AdminAccessLog[]          @relation("AccessedUser")
  buyerConversations       Conversation[]            @relation("BuyerConversations")
  sellerConversations      Conversation[]            @relation("SellerConversations")
  sentMessages             Message[]                 @relation("SentMessages")
  reportsFiled             ProductReport[]           @relation("ReporterReports")
  reportsAboutSeller       ProductReport[]           @relation("SellerReports")
  reportResolutions        ProductReport[]           @relation("AdminReportResolutions")
  sellerReportsFiled       SellerReport[]            @relation("ReporterSellerReports")
  sellerReportsReceived    SellerReport[]            @relation("SellerReportedSellerReports")
  sellerReportResolutions  SellerReport[]            @relation("AdminSellerReportResolutions")
  loginActivities          LoginActivity[]
  promotions               Promotion[]
  salesPromotions          SalesPromotion[]
  notifications            Notification[]
  buyerRefundRequests      RefundRequest[]           @relation("RefundRequestBuyer")
  sellerRefundRequests     RefundRequest[]           @relation("RefundRequestSeller")
  sellerPlanId             String?
  sellerPlan               SellerPlan?               @relation(fields: [sellerPlanId], references: [id])
  checkoutSessionSnapshots CheckoutSessionSnapshot[]
  buyerOffers              Offer[]                   @relation("BuyerOffers")
  sellerOffers             Offer[]                   @relation("SellerOffers")
  sellerTaxProfile         SellerTaxProfile?
  sellerTaxReports         SellerTaxReport[]
  // Seller subscription billing
  // Keep these nullable identifiers non-unique so production migration deploys
  // stay safe for existing databases with legacy duplicate values.
  stripeCustomerId              String?
  subscriptionId                String?
  subscriptionStatus            String?   // ACTIVE | INACTIVE | PAST_DUE | CANCELLED
  subscriptionCurrentPeriodEnd  DateTime?
  freePromotionStart            DateTime?
  freePromotionEnd              DateTime?
  hasFreePromotion              Boolean   @default(true)
  promotionCredits              Int       @default(0)
  // Legacy aliases retained for backward compatibility while existing data migrates.
  // TODO(promotion-migration): backfill and remove these aliases after all reads/writes use freePromotionStart/freePromotionEnd.
  freePromotionGrantedAt        DateTime?
  freePromotionExpiresAt        DateTime?
  // Profile picture
  image                         String?
  profileImageUrl               String?
  // Seller public shop profile (never exposes legal name to buyers)
  shopName                      String?
  shopLogoUrl                   String?
  shopDescription               String?
  // Seller ship-from address (used for live shipping rate calculation)
  shipFromName                  String?
  shipFromStreet                String?
  shipFromCity                  String?
  shipFromState                 String?
  shipFromZip                   String?
  shipFromCountry               String?
  shipFromPhone                 String?
  // Garage sales
  garageSales                   GarageSale[]  @relation("GarageSaleSeller")
  garageSalePayments            GarageSalePayment[] @relation("GarageSalePaymentSeller")
  orderShipments                OrderShipment[]     @relation("OrderShipmentSeller")
}

model SellerOtp {
  id        String   @id @default(cuid())
  userId    String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Categories ────────────────────────────────────────────────────────────────

model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  aliases         String[]   @default([])
  parentId        String?
  parent          Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryChildren")
  level           Int        @default(0) // 0=main, 1=subcategory, 2=child
  icon            String?
  sortOrder       Int        @default(0)
  /// JSON array of field definitions: [{name,label,type,options?}]
  attributeSchema Json?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Products using this category
  mainProducts    Product[]  @relation("ProductMainCategory")
  subProducts     Product[]  @relation("ProductSubCategory")

  @@index([parentId])
  @@index([level])
}

model Product {
  id                 String          @id @default(cuid())
  title              String
  description        String
  priceCents         Int
  condition          String
  category           String
  imageUrl           String
  inventory          Int             @default(1)
  shippingCents      Int             @default(0)
  status             ProductStatus   @default(PENDING)
  scheduledFor       DateTime?
  publishedAt        DateTime?
  sellerId           String
  seller             User            @relation(fields: [sellerId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  isPromoted         Boolean         @default(false)
  promotionStart     DateTime?
  promotionEnd       DateTime?
  orderItems         OrderItem[]
  conversations      Conversation[]
  reports            ProductReport[]
  promotions         Promotion[]
  rewardedSalesPromotions SalesPromotion[] @relation("SalesPromotionRewardProduct")
  cartInterest       ProductCartInterest?
  offers             Offer[]
  productVariants    ProductVariant[]
  // Pickup fields
  pickupAvailable    Boolean         @default(false)
  pickupCity         String?
  pickupState        String?
  pickupPostalCode   String?
  // Hierarchical category references (optional, for new-style listings)
  categoryId         String?
  categoryRef        Category?       @relation("ProductMainCategory", fields: [categoryId], references: [id])
  subcategoryId      String?
  subcategoryRef     Category?       @relation("ProductSubCategory", fields: [subcategoryId], references: [id])
  /// Flexible category-specific attributes stored as JSON
  productAttributes  Json?
  // Inventory analytics
  soldQty       Int       @default(0)
  viewCount     Int       @default(0)
  delistedAt    DateTime?
  lastViewedAt  DateTime?
  // Media fields (multi-image + video)
  images            String[]
  originalImages    String[]         @default([])
  enhancedImages    String[]         @default([])
  imageThumbnails   String[]         @default([])
  mainImage         String          @default("")
  videoUrl          String?
  // Package dimensions for live shipping rate calculation
  weightOz          Float?
  weightUnit        String          @default("lb")
  lengthIn          Float?
  widthIn           Float?
  heightIn          Float?
  packageType       String?         // 'PACKAGE' | 'LETTER' | 'FLAT_RATE_ENVELOPE' etc.
  /// Shipping mode: 'FLAT' uses shippingCents, 'FREE' = no cost, 'CALCULATED' = live rates
  shippingMode      String?         // 'FLAT' | 'FREE' | 'CALCULATED'

  @@index([status, category, condition])
  @@index([title])
  @@index([categoryId])
  @@index([subcategoryId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("US")
  phone      String?
  createdAt  DateTime @default(now())
}

model Order {
  id                    String      @id @default(cuid())
  buyerId               String
  buyer                 User        @relation(fields: [buyerId], references: [id])
  totalCents            Int
  subtotalCents         Int         @default(0)
  shippingCents         Int         @default(0)
  taxCents              Int         @default(0)
  platformFeeCents      Int
  sellerPayoutCents     Int         @default(0)
  status                OrderStatus @default(PENDING)
  stripeCheckoutId      String?     @unique
  stripePaymentIntentId String?
  trackingNumber        String?
  // Canonical carrier value for new shipping-label flows.
  carrier               String?
  shippingService       String?
  // Legacy field kept for backwards-compatible API/mobile payloads.
  shippingCarrier       String?
  trackingUrl           String?
  labelUrl              String?
  labelPurchaseIdempotencyKey String?
  labelProviderTransactionId  String?
  labelPurchasedAt      DateTime?
  labelPurchaseLastError String?
  shipmentStatus        String?
  shipmentId            String?
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  // Pickup fields
  isPickup              Boolean     @default(false)
  pickupCity            String?
  pickupState           String?
  // Pickup confirmation
  pickupCode            String?
  pickupCodeAttempts    Int         @default(0)
  pickupConfirmedAt     DateTime?
  pickupConfirmedById   String?
  // Stored shipment + selected-rate IDs for auto-label creation after payment
  selectedShipmentId    String?
  selectedRateId        String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]
  refundRequest         RefundRequest?
  shipments             OrderShipment[]
}

model RefundRequest {
  id                   String              @id @default(cuid())
  orderId              String              @unique
  order                Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyerId              String
  buyer                User                @relation("RefundRequestBuyer", fields: [buyerId], references: [id])
  sellerId             String
  seller               User                @relation("RefundRequestSeller", fields: [sellerId], references: [id])
  status               RefundRequestStatus @default(REQUESTED)
  reason               String
  details              String?
  evidenceUrls         String[]            @default([])
  requestedAmountCents Int
  approvedAmountCents  Int?
  adminNotes           String?
  sellerResponse       String?
  stripeRefundId       String?
  stripeRefundStatus   String?
  stripeRefundAmount   Int?
  stripeRefundCurrency String?
  stripeFailureReason  String?
  stripeErrorCode      String?
  stripeErrorMessage   String?
  stripeRefundCreatedAt DateTime?
  stripeRefundUpdatedAt DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  resolvedAt           DateTime?

  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
  @@index([status, createdAt])
}

model SellerRefundHistory {
  id                    String   @id @default(cuid())
  sellerId              String
  orderId               String?
  saleId                String?
  refundType            String
  sourceLabel           String?
  sourceKey             String   @unique
  stripePaymentIntentId String?
  stripeRefundId        String?  @unique
  amountCents           Int?
  currency              String?
  status                String
  reason                String?
  refundedAt            DateTime?
  resolvedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sellerId, createdAt])
  @@index([orderId])
  @@index([saleId])
  @@index([stripePaymentIntentId])
}

model OrderItem {
  id                 String  @id @default(cuid())
  orderId            String
  order              Order   @relation(fields: [orderId], references: [id])
  productId          String
  product            Product @relation(fields: [productId], references: [id])
  productVariantId   String?
  productVariant     ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  sizeType           ProductSizeType?
  sizeLabel          String?
  waist              String?
  length             String?
  priceCents         Int
  shippingCents      Int     @default(0)
  quantity           Int     @default(1)
  lineSubtotalCents  Int     @default(0)
  commissionRateBps  Int     @default(700)
  commissionFeeCents Int     @default(0)
  sellerNetCents     Int     @default(0)
  commissionSource   String  @default("DEFAULT")
  commissionPlanCode String?

  @@index([productVariantId])
}

model ProductVariant {
  id         String          @id @default(cuid())
  productId  String
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizeType   ProductSizeType
  sizeLabel  String?
  waist      String?
  length     String?
  quantity   Int             @default(0)
  isAvailable Boolean        @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  orderItems OrderItem[]

  @@index([productId])
}

/// Per-seller shipment/tracking record for an order. Multi-seller orders store
/// one row per seller so shipment state and tracking data are tracked independently.
model OrderShipment {
  id                          String    @id @default(cuid())
  orderId                     String
  order                       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId                    String
  seller                      User      @relation("OrderShipmentSeller", fields: [sellerId], references: [id])
  shipmentId                  String?
  shipmentStatus              String?
  trackingNumber              String?
  carrier                     String?
  shippingService             String?
  labelUrl                    String?
  trackingUrl                 String?
  labelPurchaseIdempotencyKey String?
  labelProviderTransactionId  String?
  labelPurchasedAt            DateTime?
  labelPurchaseLastError      String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@unique([orderId, sellerId])
  @@index([orderId])
  @@index([sellerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SellerModerationLog {
  id             String   @id @default(cuid())
  sellerId       String
  seller         User     @relation("ModeratedSeller", fields: [sellerId], references: [id])
  adminId        String
  admin          User     @relation("AdminModerator", fields: [adminId], references: [id])
  action         String // SUSPENDED | BANNED | REINSTATED
  reasonCategory String?
  notes          String?
  createdAt      DateTime @default(now())

  @@index([sellerId])
}

model SellerVerification {
  id                           String                         @id @default(cuid())
  sellerId                     String                         @unique
  seller                       User                           @relation("SellerVerificationSubmission", fields: [sellerId], references: [id], onDelete: Cascade)
  provider                     SellerKycProvider              @default(STRIPE)
  providerAccountId            String?
  providerInquiryId            String?
  providerVerificationId       String?
  providerStatus               String?
  status                       SellerVerificationStatus       @default(PENDING)
  rejectionReason              String?
  governmentIdVerified         Boolean                        @default(false)
  selfieVerified               Boolean                        @default(false)
  addressVerified              Boolean                        @default(false)
  phoneVerified                Boolean                        @default(false)
  phoneNumber                  String
  phoneVerificationStatus      SellerPhoneVerificationStatus  @default(NOT_STARTED)
  street                       String
  city                         String
  state                        String
  zipCode                      String
  country                      String
  governmentIdFrontPublicId    String
  governmentIdFrontFormat      String?
  governmentIdBackPublicId     String
  governmentIdBackFormat       String?
  selfieImagePublicId          String
  selfieImageFormat            String?
  kycStartedAt                 DateTime?
  providerReviewedAt           DateTime?
  eligibleToListAt             DateTime?
  verifiedAt                   DateTime?
  adminFallbackStatus          SellerAdminFallbackStatus      @default(NOT_REQUIRED)
  adminFallbackReason          String?
  webhookLastEventId           String?
  webhookLastReceivedAt        DateTime?
  reviewedAt                   DateTime?
  reviewedById                 String?
  reviewedBy                   User?                          @relation("SellerVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt

  @@index([status])
}

model PhoneVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminAccessLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminAccessor", fields: [adminId], references: [id])
  targetId  String
  target    User     @relation("AccessedUser", fields: [targetId], references: [id])
  action    String
  notes     String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

// ── Messaging ─────────────────────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  buyerId   String
  buyer     User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  sellerId  String
  seller    User      @relation("SellerConversations", fields: [sellerId], references: [id])
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // One active thread per buyer/seller/product combination
  @@unique([buyerId, sellerId, productId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  data      Json?
  dedupeKey String?          @unique
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Offer {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User        @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User        @relation("SellerOffers", fields: [sellerId], references: [id], onDelete: Cascade)
  amountCents Int
  message     String?
  status      OfferStatus @default(PENDING)
  respondedAt DateTime?
  expiresAt   DateTime?
  checkoutSessionId        String?   @unique
  checkoutSessionExpiresAt DateTime?
  convertedOrderId         String?   @unique
  convertedAt              DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([productId])
  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
  @@index([status])
}

// ── Product Reporting ─────────────────────────────────────────────────────────

model ProductReport {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  reporterId  String
  reporter    User         @relation("ReporterReports", fields: [reporterId], references: [id])
  sellerId    String
  seller      User         @relation("SellerReports", fields: [sellerId], references: [id])
  reason      String
  notes       String?
  status      ReportStatus @default(OPEN)
  adminId     String?
  admin       User?        @relation("AdminReportResolutions", fields: [adminId], references: [id])
  adminAction String?
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // One open report per reporter/product/reason (prevent spam)
  @@unique([reporterId, productId, reason])
  @@index([productId])
  @@index([sellerId])
  @@index([status])
}

model SellerReport {
  id          String       @id @default(cuid())
  sellerId    String
  seller      User         @relation("SellerReportedSellerReports", fields: [sellerId], references: [id])
  reporterId  String
  reporter    User         @relation("ReporterSellerReports", fields: [reporterId], references: [id])
  reason      String
  notes       String?
  status      ReportStatus @default(OPEN)
  adminId     String?
  admin       User?        @relation("AdminSellerReportResolutions", fields: [adminId], references: [id])
  adminAction String?
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([reporterId, sellerId, reason])
  @@index([sellerId])
  @@index([status])
}

model LoginActivity {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipHash            String?
  ipLabel           String?
  deviceHash        String?
  deviceLabel       String?
  suspicious        Boolean  @default(false)
  suspiciousReasons String[]
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([suspicious, createdAt])
}

// ── Product Promotions ────────────────────────────────────────────────────────

model Promotion {
  id               String          @id @default(cuid())
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  sellerId         String
  seller           User            @relation(fields: [sellerId], references: [id])
  status           PromotionStatus @default(PENDING_PAYMENT)
  durationDays     Int
  priceCents       Int
  impressionCount  Int             @default(0)
  clickCount       Int             @default(0)
  saleCount        Int             @default(0)
  saleAmountCents  Int             @default(0)
  stripeCheckoutId String?         @unique
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([productId])
  @@index([sellerId])
  @@index([status])
}

model SalesPromotion {
  id                 String                       @id @default(cuid())
  sellerId           String
  seller             User                         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  kind               SalesPromotionKind
  status             SalesPromotionStatus         @default(DRAFT)
  name               String
  description        String?
  discountType       SellerDiscountType?
  discountValue      Int?
  triggerType        SellerPromotionTriggerType?
  triggerValue       Int?
  rewardType         SellerPromotionRewardType?
  rewardProductId    String?
  rewardProduct      Product?                     @relation("SalesPromotionRewardProduct", fields: [rewardProductId], references: [id], onDelete: SetNull)
  rewardQuantity     Int                          @default(1)
  applicableProductIds String[]                  @default([])
  totalUsageLimit    Int?
  perCustomerLimit   Int?
  usageCount         Int                          @default(0)
  conversionCount    Int                          @default(0)
  revenueImpactCents Int                          @default(0)
  startsAt           DateTime?
  endsAt             DateTime?
  archivedAt         DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([sellerId, kind, status])
  @@index([sellerId, startsAt])
  @@index([rewardProductId])
}

model PromotionPlan {
  id           String   @id @default(cuid())
  durationDays Int      @unique
  label        String
  description  String?
  priceCents   Int
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model MarketplaceSettings {
  id                         Int      @id @default(1)
  defaultSellerCommissionBps Int      @default(700)
  freePromotionEnabled       Boolean  @default(true)
  freePromotionDurationDays  Int      @default(60)
  garageStandardPriceCents   Int      @default(299)
  garageFeaturedPriceCents   Int      @default(699)
  garageHomepagePromoEnabled Boolean  @default(true)
  garageHomepagePromoCents   Int      @default(499)
  garageTopSearchEnabled     Boolean  @default(true)
  garageTopSearchCents       Int      @default(399)
  garageFirstListingFree     Boolean  @default(false)
  /// When false (default) all seller monthly subscription fees are waived — FREE TIER.
  /// Set to true to re-enable monthly billing.  Only the 7% transaction fee applies when false.
  sellerSubscriptionFeeEnabled Boolean @default(false)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model SellerPlan {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  commissionRateBps Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sellers           User[]
}

model ProductCartInterest {
  id          String   @id @default(cuid())
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  totalAdds   Int      @default(0)
  lastAddedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lastAddedAt])
}

model VisitorMetric {
  id          String   @id @default(cuid())
  visitorHash String
  bucketDate  DateTime
  createdAt   DateTime @default(now())

  @@unique([visitorHash, bucketDate])
  @@index([bucketDate])
}

model CheckoutSessionSnapshot {
  stripeCheckoutId String   @id
  buyerId          String
  buyer            User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items            Json
  pickupItemIds    Json
  commissionItems  Json
  directToSellerId String?
  /// Verified live shipping rate info:
  /// { totalRateCents, shipmentGroups: [{sellerId, shipmentId, rateId, rateCents, carrier, service, package, itemSnapshot}], buyerAddress, verification }
  shippingRateInfo Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([buyerId])
}

// ── Seller Tax Center ─────────────────────────────────────────────────────────

enum Form1099Status {
  NOT_ELIGIBLE
  PENDING
  AVAILABLE
  FILED
}

enum TaxIdStatus {
  NOT_PROVIDED
  PENDING
  PROVIDED
}

model SellerTaxProfile {
  id                 String   @id @default(cuid())
  sellerId           String   @unique
  seller             User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  legalName          String?
  businessName       String?
  // Masked/status-only tax ID. Raw SSN/EIN must never be stored here.
  taxIdStatus        TaxIdStatus @default(NOT_PROVIDED)
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  postalCode         String?
  country            String?
  verificationStatus String?  // mirrors SellerVerification status for convenience
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SellerTaxReport {
  id                     String         @id @default(cuid())
  sellerId               String
  seller                 User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  taxYear                Int
  grossSalesCents        Int            @default(0)
  totalOrders            Int            @default(0)
  refundsCents           Int            @default(0)
  marketplaceFeesCents   Int            @default(0)
  paymentFeesCents       Int            @default(0)
  netPayoutsCents        Int            @default(0)
  salesTaxCollectedCents Int            @default(0)
  form1099Status         Form1099Status @default(NOT_ELIGIBLE)
  form1099DownloadUrl    String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([sellerId, taxYear])
  @@index([sellerId])
  @@index([taxYear])
}

model GarageSale {
  id               String               @id @default(cuid())
  sellerId         String
  seller           User                 @relation("GarageSaleSeller", fields: [sellerId], references: [id])
  title            String
  description      String
  saleType         GarageSaleType       @default(GARAGE_SALE)
  listingType      GarageSaleListingType @default(STANDARD)
  status           GarageSaleStatus     @default(PENDING)
  // Location
  address          String
  city             String
  state            String
  zipCode          String
  latitude         Float?
  longitude        Float?
  // Schedule
  startDate        DateTime
  endDate          DateTime
  expirationTimestamp DateTime
  durationDays     Int                  @default(1)
  // Media
  photos           String[]             @default([])
  videoUrl         String?
  // Categories (JSON array of strings from the predefined list)
  categories       String[]             @default([])
  // Contact
  sellerPhone      String?
  // Price range
  priceRangeMin    Float?
  priceRangeMax    Float?
  // Features
  isFeatured       Boolean              @default(false)
  promotionType    GarageSalePromotionType?
  promotionStart   DateTime?
  promotionEnd     DateTime?
  homepagePromoted Boolean              @default(false)
  topSearchPromoted Boolean             @default(false)
  pricePerDayCents Int                  @default(299)
  baseAmountCents  Int                  @default(0)
  addOnsAmountCents Int                 @default(0)
  totalPaidCents   Int                  @default(0)
  paymentStatus    GarageSalePaymentStatus @default(PENDING)
  stripeCheckoutId String?              @unique
  stripePaymentId  String?
  paidAt           DateTime?
  activatedAt      DateTime?
  archivedAt       DateTime?
  isArchived       Boolean              @default(false)
  repostOfId       String?
  repostOf         GarageSale?          @relation("GarageSaleReposts", fields: [repostOfId], references: [id])
  reposts          GarageSale[]         @relation("GarageSaleReposts")
  payments         GarageSalePayment[]
  // Analytics
  viewCount        Int                  @default(0)
  // Moderation
  adminNotes       String?
  isSpam           Boolean              @default(false)
  // Reports
  reports          GarageSaleReport[]
  // Favorites
  favorites        GarageSaleFavorite[]
  chatMessages     GarageSaleChat[]
  reactions        GarageSaleReaction[]
  liveSignals      GarageSaleLiveSignal[]
  guestRequests    GarageSaleGuestRequest[]
  // Live preview
  isLive           Boolean              @default(false)
  liveStartedAt    DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([sellerId])
  @@index([status])
  @@index([isLive])
  @@index([paymentStatus])
  @@index([city, state])
  @@index([zipCode])
  @@index([startDate, endDate])
  @@index([expirationTimestamp])
  @@index([isFeatured])
  @@index([latitude, longitude])
}

model GarageSalePayment {
  id              String                 @id @default(cuid())
  saleId          String
  sale            GarageSale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sellerId        String
  seller          User                   @relation("GarageSalePaymentSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  amountCents     Int
  status          GarageSalePaymentStatus @default(PENDING)
  stripeCheckoutId String?               @unique
  stripePaymentId String?
  stripeReceiptUrl String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([saleId])
  @@index([sellerId])
  @@index([status])
}

model GarageSaleReport {
  id           String      @id @default(cuid())
  saleId       String
  sale         GarageSale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  reporterId   String
  reason       String
  notes        String?
  status       ReportStatus @default(OPEN)
  adminNotes   String?
  resolvedAt   DateTime?
  createdAt    DateTime    @default(now())

  @@unique([saleId, reporterId])
  @@index([saleId])
  @@index([status])
}

model GarageSaleFavorite {
  id        String     @id @default(cuid())
  saleId    String
  sale      GarageSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime   @default(now())

  @@unique([saleId, userId])
  @@index([userId])
}

model GarageSaleChat {
  id        String     @id @default(cuid())
  saleId    String
  sale      GarageSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId    String?
  sellerId  String?
  guestName String?
  message   String     @db.VarChar(500)
  isHidden  Boolean    @default(false)
  createdAt DateTime   @default(now())

  @@index([saleId])
  @@index([saleId, sellerId])
  @@index([saleId, isHidden])
  @@index([createdAt])
}

model GarageSaleReaction {
  id        String     @id @default(cuid())
  saleId    String
  sale      GarageSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId    String?
  guestId   String?
  type      String     @default("like") // like | heart
  createdAt DateTime   @default(now())

  @@index([saleId, createdAt])
  @@index([saleId, type])
}

model GarageSaleLiveSignal {
  id        String     @id @default(cuid())
  saleId    String
  sale      GarageSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sender    String
  kind      String
  payload   Json
  createdAt DateTime   @default(now())

  @@index([saleId, createdAt])
  @@index([saleId, sender, kind])
}

/// Tracks buyer requests to join the seller live as a video guest.
/// Status flow: pending → accepted / declined / removed
model GarageSaleGuestRequest {
  id        String     @id @default(cuid())
  saleId    String     @map("liveSaleId")
  sale      GarageSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  sellerId  String
  viewerId  String
  /// Stable anonymous identifier generated in the buyer's browser.
  guestId   String
  guestName String?
  viewerAvatar String? @map("viewerAvatar")
  /// pending | accepted | declined | removed
  status    String     @default("pending")
  isMuted   Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([saleId, status])
  @@index([saleId, guestId])
  @@index([saleId, viewerId])
  @@index([sellerId, status])
  @@map("live_join_requests")
}

// ─── Founding Seller Program ─────────────────────────────────────────────────

/// Tracks enrollment in the limited (1,000-seat) Founding Seller Program.
model FoundingSellerProgram {
  id                   String   @id @default(cuid())
  userId               String   @unique
  enrollmentDate       DateTime @default(now())
  expiryDate           DateTime
  /// Sequential founder number (1–1000).
  foundingSellerNumber Int      @unique
  /// ACTIVE | EXPIRED | TRANSITIONED
  status               String   @default("ACTIVE")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([foundingSellerNumber])
}

/// Tracks seller subscription state across plan types.
model SellerSubscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  /// FOUNDING | GARAGE_SELLER | REGULAR_SELLER
  type            String
  /// ACTIVE | EXPIRED | CANCELLED
  status          String   @default("ACTIVE")
  /// Monthly fee in cents (0 for founding year).
  monthlyFeeCents Int      @default(0)
  nextBillingDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
}
