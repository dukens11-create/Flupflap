generator client {
  provider = "prisma-client-js"
}

// Database connection URL is configured in prisma.config.ts (Prisma 7 pattern)
datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

enum SellerStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum SellerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SellerPhoneVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
}

enum SellerKycProvider {
  STRIPE
  PERSONA
  MANUAL
}

enum SellerAdminFallbackStatus {
  NOT_REQUIRED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
  HIDDEN
}

enum ReportStatus {
  OPEN
  DISMISSED
  RESOLVED
}

enum PromotionStatus {
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum NotificationType {
  ORDER_UPDATE
  OFFER
  MESSAGE
  PAYOUT
  SHIPPING
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  READY_FOR_PICKUP
  PICKED_UP
}

model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  password                 String
  role                     Role                      @default(CUSTOMER)
  phone                    String?
  stripeAccountId          String?
  stripeAccountMode        String?
  stripeOnboardingComplete Boolean                   @default(false)
  deletedAt                DateTime?
  deletionReason           String?
  deletionReasonOther      String?
  sellerStatus             SellerStatus              @default(ACTIVE)
  sellerStatusReason       String?
  sellerStatusNotes        String?
  phoneVerified            Boolean                   @default(false)
  phoneVerifiedAt          DateTime?
  createdAt                DateTime                  @default(now())
  products                 Product[]
  orders                   Order[]
  addresses                Address[]
  accounts                 Account[]
  sessions                 Session[]
  sellerOtp                SellerOtp?
  phoneVerificationToken   PhoneVerificationToken?
  verificationSubmission   SellerVerification?        @relation("SellerVerificationSubmission")
  reviewedVerifications    SellerVerification[]       @relation("SellerVerificationReviewer")
  moderationLogsAsSeller   SellerModerationLog[]     @relation("ModeratedSeller")
  moderationLogsAsAdmin    SellerModerationLog[]     @relation("AdminModerator")
  adminAccessLogs          AdminAccessLog[]          @relation("AdminAccessor")
  accessedByAdminLogs      AdminAccessLog[]          @relation("AccessedUser")
  buyerConversations       Conversation[]            @relation("BuyerConversations")
  sellerConversations      Conversation[]            @relation("SellerConversations")
  sentMessages             Message[]                 @relation("SentMessages")
  reportsFiled             ProductReport[]           @relation("ReporterReports")
  reportsAboutSeller       ProductReport[]           @relation("SellerReports")
  reportResolutions        ProductReport[]           @relation("AdminReportResolutions")
  sellerReportsFiled       SellerReport[]            @relation("ReporterSellerReports")
  sellerReportsReceived    SellerReport[]            @relation("SellerReportedSellerReports")
  sellerReportResolutions  SellerReport[]            @relation("AdminSellerReportResolutions")
  loginActivities          LoginActivity[]
  promotions               Promotion[]
  notifications            Notification[]
  sellerPlanId             String?
  sellerPlan               SellerPlan?               @relation(fields: [sellerPlanId], references: [id])
  checkoutSessionSnapshots CheckoutSessionSnapshot[]
  buyerOffers              Offer[]                   @relation("BuyerOffers")
  sellerOffers             Offer[]                   @relation("SellerOffers")
  sellerTaxProfile         SellerTaxProfile?
  sellerTaxReports         SellerTaxReport[]
  // Seller subscription billing
  // Keep these nullable identifiers non-unique so production `prisma db push`
  // stays deploy-safe for existing databases with legacy duplicate values.
  stripeCustomerId              String?
  subscriptionId                String?
  subscriptionStatus            String?   // ACTIVE | INACTIVE | PAST_DUE | CANCELLED
  subscriptionCurrentPeriodEnd  DateTime?
  freePromotionStart            DateTime?
  freePromotionEnd              DateTime?
  hasFreePromotion              Boolean   @default(true)
  promotionCredits              Int       @default(0)
  // Legacy aliases retained for backward compatibility while existing data migrates.
  // TODO(promotion-migration): backfill and remove these aliases after all reads/writes use freePromotionStart/freePromotionEnd.
  freePromotionGrantedAt        DateTime?
  freePromotionExpiresAt        DateTime?
  // Profile picture
  image                         String?
}

model SellerOtp {
  id        String   @id @default(cuid())
  userId    String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id               String          @id @default(cuid())
  title            String
  description      String
  priceCents       Int
  condition        String
  category         String
  imageUrl         String
  inventory        Int             @default(1)
  shippingCents    Int             @default(0)
  status           ProductStatus   @default(PENDING)
  sellerId         String
  seller           User            @relation(fields: [sellerId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isPromoted       Boolean         @default(false)
  promotionStart   DateTime?
  promotionEnd     DateTime?
  orderItems       OrderItem[]
  conversations    Conversation[]
  reports          ProductReport[]
  promotions       Promotion[]
  cartInterest     ProductCartInterest?
  offers           Offer[]
  // Pickup fields
  pickupAvailable  Boolean         @default(false)
  pickupCity       String?
  pickupState      String?
  pickupPostalCode String?

  @@index([status, category, condition])
  @@index([title])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("US")
  phone      String?
  createdAt  DateTime @default(now())
}

model Order {
  id                    String      @id @default(cuid())
  buyerId               String
  buyer                 User        @relation(fields: [buyerId], references: [id])
  totalCents            Int
  subtotalCents         Int         @default(0)
  shippingCents         Int         @default(0)
  taxCents              Int         @default(0)
  platformFeeCents      Int
  sellerPayoutCents     Int         @default(0)
  status                OrderStatus @default(PENDING)
  stripeCheckoutId      String?     @unique
  stripePaymentIntentId String?
  trackingNumber        String?
  // Canonical carrier value for new shipping-label flows.
  carrier               String?
  // Legacy field kept for backwards-compatible API/mobile payloads.
  shippingCarrier       String?
  labelUrl              String?
  shipmentStatus        String?
  shipmentId            String?
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  // Pickup fields
  isPickup              Boolean     @default(false)
  pickupCity            String?
  pickupState           String?
  // Pickup confirmation
  pickupCode            String?
  pickupCodeAttempts    Int         @default(0)
  pickupConfirmedAt     DateTime?
  pickupConfirmedById   String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]
}

model OrderItem {
  id                 String  @id @default(cuid())
  orderId            String
  order              Order   @relation(fields: [orderId], references: [id])
  productId          String
  product            Product @relation(fields: [productId], references: [id])
  priceCents         Int
  shippingCents      Int     @default(0)
  quantity           Int     @default(1)
  lineSubtotalCents  Int     @default(0)
  commissionRateBps  Int     @default(700)
  commissionFeeCents Int     @default(0)
  sellerNetCents     Int     @default(0)
  commissionSource   String  @default("DEFAULT")
  commissionPlanCode String?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SellerModerationLog {
  id             String   @id @default(cuid())
  sellerId       String
  seller         User     @relation("ModeratedSeller", fields: [sellerId], references: [id])
  adminId        String
  admin          User     @relation("AdminModerator", fields: [adminId], references: [id])
  action         String // SUSPENDED | BANNED | REINSTATED
  reasonCategory String?
  notes          String?
  createdAt      DateTime @default(now())

  @@index([sellerId])
}

model SellerVerification {
  id                           String                         @id @default(cuid())
  sellerId                     String                         @unique
  seller                       User                           @relation("SellerVerificationSubmission", fields: [sellerId], references: [id], onDelete: Cascade)
  provider                     SellerKycProvider              @default(STRIPE)
  providerAccountId            String?
  providerInquiryId            String?
  providerVerificationId       String?
  providerStatus               String?
  status                       SellerVerificationStatus       @default(PENDING)
  rejectionReason              String?
  governmentIdVerified         Boolean                        @default(false)
  selfieVerified               Boolean                        @default(false)
  addressVerified              Boolean                        @default(false)
  phoneVerified                Boolean                        @default(false)
  phoneNumber                  String
  phoneVerificationStatus      SellerPhoneVerificationStatus  @default(NOT_STARTED)
  street                       String
  city                         String
  state                        String
  zipCode                      String
  country                      String
  governmentIdFrontPublicId    String
  governmentIdFrontFormat      String?
  governmentIdBackPublicId     String
  governmentIdBackFormat       String?
  selfieImagePublicId          String
  selfieImageFormat            String?
  kycStartedAt                 DateTime?
  providerReviewedAt           DateTime?
  eligibleToListAt             DateTime?
  verifiedAt                   DateTime?
  adminFallbackStatus          SellerAdminFallbackStatus      @default(NOT_REQUIRED)
  adminFallbackReason          String?
  webhookLastEventId           String?
  webhookLastReceivedAt        DateTime?
  reviewedAt                   DateTime?
  reviewedById                 String?
  reviewedBy                   User?                          @relation("SellerVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt

  @@index([status])
}

model PhoneVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminAccessLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation("AdminAccessor", fields: [adminId], references: [id])
  targetId  String
  target    User     @relation("AccessedUser", fields: [targetId], references: [id])
  action    String
  notes     String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetId])
}

// ── Messaging ─────────────────────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  buyerId   String
  buyer     User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  sellerId  String
  seller    User      @relation("SellerConversations", fields: [sellerId], references: [id])
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // One active thread per buyer/seller/product combination
  @@unique([buyerId, sellerId, productId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  attachmentUrl  String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  link      String?
  data      Json?
  dedupeKey String?          @unique
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Offer {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User        @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User        @relation("SellerOffers", fields: [sellerId], references: [id], onDelete: Cascade)
  amountCents Int
  message     String?
  status      OfferStatus @default(PENDING)
  respondedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([productId])
  @@index([buyerId, createdAt])
  @@index([sellerId, createdAt])
  @@index([status])
}

// ── Product Reporting ─────────────────────────────────────────────────────────

model ProductReport {
  id          String       @id @default(cuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  reporterId  String
  reporter    User         @relation("ReporterReports", fields: [reporterId], references: [id])
  sellerId    String
  seller      User         @relation("SellerReports", fields: [sellerId], references: [id])
  reason      String
  notes       String?
  status      ReportStatus @default(OPEN)
  adminId     String?
  admin       User?        @relation("AdminReportResolutions", fields: [adminId], references: [id])
  adminAction String?
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // One open report per reporter/product/reason (prevent spam)
  @@unique([reporterId, productId, reason])
  @@index([productId])
  @@index([sellerId])
  @@index([status])
}

model SellerReport {
  id          String       @id @default(cuid())
  sellerId    String
  seller      User         @relation("SellerReportedSellerReports", fields: [sellerId], references: [id])
  reporterId  String
  reporter    User         @relation("ReporterSellerReports", fields: [reporterId], references: [id])
  reason      String
  notes       String?
  status      ReportStatus @default(OPEN)
  adminId     String?
  admin       User?        @relation("AdminSellerReportResolutions", fields: [adminId], references: [id])
  adminAction String?
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([reporterId, sellerId, reason])
  @@index([sellerId])
  @@index([status])
}

model LoginActivity {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipHash            String?
  ipLabel           String?
  deviceHash        String?
  deviceLabel       String?
  suspicious        Boolean  @default(false)
  suspiciousReasons String[]
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
  @@index([suspicious, createdAt])
}

// ── Product Promotions ────────────────────────────────────────────────────────

model Promotion {
  id               String          @id @default(cuid())
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  sellerId         String
  seller           User            @relation(fields: [sellerId], references: [id])
  status           PromotionStatus @default(PENDING_PAYMENT)
  durationDays     Int
  priceCents       Int
  impressionCount  Int             @default(0)
  clickCount       Int             @default(0)
  saleCount        Int             @default(0)
  saleAmountCents  Int             @default(0)
  stripeCheckoutId String?         @unique
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([productId])
  @@index([sellerId])
  @@index([status])
}

model PromotionPlan {
  id           String   @id @default(cuid())
  durationDays Int      @unique
  label        String
  description  String?
  priceCents   Int
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model MarketplaceSettings {
  id                         Int      @id @default(1)
  defaultSellerCommissionBps Int      @default(700)
  freePromotionEnabled       Boolean  @default(true)
  freePromotionDurationDays  Int      @default(60)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model SellerPlan {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  commissionRateBps Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sellers           User[]
}

model ProductCartInterest {
  id          String   @id @default(cuid())
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  totalAdds   Int      @default(0)
  lastAddedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([lastAddedAt])
}

model VisitorMetric {
  id          String   @id @default(cuid())
  visitorHash String
  bucketDate  DateTime
  createdAt   DateTime @default(now())

  @@unique([visitorHash, bucketDate])
  @@index([bucketDate])
}

model CheckoutSessionSnapshot {
  stripeCheckoutId String   @id
  buyerId          String
  buyer            User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items            Json
  pickupItemIds    Json
  commissionItems  Json
  directToSellerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([buyerId])
}

// ── Seller Tax Center ─────────────────────────────────────────────────────────

enum Form1099Status {
  NOT_ELIGIBLE
  PENDING
  AVAILABLE
  FILED
}

enum TaxIdStatus {
  NOT_PROVIDED
  PENDING
  PROVIDED
}

model SellerTaxProfile {
  id                 String   @id @default(cuid())
  sellerId           String   @unique
  seller             User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  legalName          String?
  businessName       String?
  // Masked/status-only tax ID. Raw SSN/EIN must never be stored here.
  taxIdStatus        TaxIdStatus @default(NOT_PROVIDED)
  addressLine1       String?
  addressLine2       String?
  city               String?
  state              String?
  postalCode         String?
  country            String?
  verificationStatus String?  // mirrors SellerVerification status for convenience
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SellerTaxReport {
  id                     String         @id @default(cuid())
  sellerId               String
  seller                 User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  taxYear                Int
  grossSalesCents        Int            @default(0)
  totalOrders            Int            @default(0)
  refundsCents           Int            @default(0)
  marketplaceFeesCents   Int            @default(0)
  paymentFeesCents       Int            @default(0)
  netPayoutsCents        Int            @default(0)
  salesTaxCollectedCents Int            @default(0)
  form1099Status         Form1099Status @default(NOT_ELIGIBLE)
  form1099DownloadUrl    String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([sellerId, taxYear])
  @@index([sellerId])
  @@index([taxYear])
}
