generator client {
  provider = "prisma-client-js"
}

// Database connection URL is configured in prisma.config.ts (Prisma 7 pattern)
datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

enum SellerStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  READY_FOR_PICKUP
  PICKED_UP
}

model User {
  id                       String        @id @default(cuid())
  name                     String
  email                    String        @unique
  password                 String
  role                     Role          @default(CUSTOMER)
  phone                    String?
  stripeAccountId          String?
  stripeOnboardingComplete Boolean       @default(false)
  sellerStatus             SellerStatus  @default(ACTIVE)
  sellerStatusReason       String?
  sellerStatusNotes        String?
  createdAt                DateTime      @default(now())
  products                 Product[]
  orders                   Order[]
  addresses                Address[]
  accounts                 Account[]
  sessions                 Session[]
  sellerOtp                SellerOtp?
  moderationLogsAsSeller   SellerModerationLog[] @relation("ModeratedSeller")
  moderationLogsAsAdmin    SellerModerationLog[] @relation("AdminModerator")
  adminAccessLogsAsAdmin   AdminAccessLog[]      @relation("AdminAccessor")
  adminAccessLogsAsTarget  AdminAccessLog[]      @relation("AccessedUser")
}

model SellerOtp {
  id        String   @id @default(cuid())
  userId    String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id            String        @id @default(cuid())
  title         String
  description   String
  priceCents    Int
  condition     String
  category      String
  imageUrl      String
  inventory     Int           @default(1)
  shippingCents Int           @default(0)
  status        ProductStatus @default(PENDING)
  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  orderItems    OrderItem[]

  // Pickup fields
  pickupAvailable  Boolean @default(false)
  pickupCity       String?
  pickupState      String?
  pickupPostalCode String?
  pickupLat        Float?
  pickupLng        Float?

  @@index([status, category, condition])
  @@index([title])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("US")
  phone      String?
  createdAt  DateTime @default(now())
}

model Order {
  id                    String      @id @default(cuid())
  buyerId               String
  buyer                 User        @relation(fields: [buyerId], references: [id])
  totalCents            Int
  subtotalCents         Int         @default(0)
  shippingCents         Int         @default(0)
  taxCents              Int         @default(0)
  platformFeeCents      Int
  sellerPayoutCents     Int         @default(0)
  status                OrderStatus @default(PENDING)
  stripeCheckoutId      String?     @unique
  stripePaymentIntentId String?
  trackingNumber        String?
  shippingCarrier       String?
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]

  // Pickup fields
  isPickup              Boolean     @default(false)
  pickupCity            String?
  pickupState           String?
  pickupConfirmation    PickupConfirmation?
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  priceCents Int
  quantity   Int    @default(1)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SellerModerationLog {
  id             String   @id @default(cuid())
  sellerId       String
  seller         User     @relation("ModeratedSeller", fields: [sellerId], references: [id])
  adminId        String
  admin          User     @relation("AdminModerator", fields: [adminId], references: [id])
  action         String   // SUSPENDED | BANNED | REINSTATED
  reasonCategory String?
  notes          String?
  createdAt      DateTime @default(now())

  @@index([sellerId])
}

model PickupConfirmation {
  id          String    @id @default(cuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id])
  code        String    // 6-character alphanumeric pickup code (unambiguous chars)
  confirmedAt DateTime?
  confirmedBy String?   // seller userId who verified the code
  createdAt   DateTime  @default(now())
}

model AdminAccessLog {
  id           String   @id @default(cuid())
  adminId      String
  admin        User     @relation("AdminAccessor", fields: [adminId], references: [id])
  targetUserId String
  targetUser   User     @relation("AccessedUser", fields: [targetUserId], references: [id])
  reason       String?
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
}
